# ============================================================
# Crowd Monitoring — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
# Full MongoDB connection string
MONGO_URI=mongodb://localhost:27017
# Database and collection names
MONGO_DB=home
MONGO_COLLECTION=blogs

# ── Node.js API server ───────────────────────────────────────
# Used by detection engine to push crowd counts
NODE_SERVER_URL=http://localhost:3000
# Port the Node server listens on
PORT=3000

# ── Python Crowd API server ──────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Secret key for signed tokens / HMAC; change in production!
API_SECRET_KEY=changeme-in-production

# ── Provider chain ───────────────────────────────────────────
# Comma-separated ordered list of provider names to use.
# Tried left-to-right; first successful response wins.
# Available: roboflow, huggingface, geospatial, opencv
PROVIDER_CHAIN=roboflow,huggingface,geospatial,opencv

# ── Roboflow (Primary API provider) ─────────────────────────
# Get a free key at https://roboflow.com
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=crowd-counting
ROBOFLOW_MODEL_ID=crowd-counting-1
ROBOFLOW_MODEL_VERSION=1

# ── HuggingFace (Secondary — local or API) ──────────────────
# Model used for local object detection (no key required for local)
HF_MODEL=facebook/detr-resnet-50
# Optional: HuggingFace Inference API key (free tier available)
HF_API_KEY=

# ── OpenCV provider (legacy fallback) ───────────────────────
OPENCV_PROTOTXT=MobileNetSSD_deploy.prototxt
OPENCV_CAFFEMODEL=MobileNetSSD_deploy.caffemodel
OPENCV_CONFIDENCE_THRESHOLD=0.4
OPENCV_FRAME_SKIP=5

# ── Camera sources ───────────────────────────────────────────
CAMERAS_FILE=cameras.json

# ── Resiliency / circuit breaker ─────────────────────────────
PROVIDER_TIMEOUT_SECONDS=10.0
PROVIDER_MAX_RETRIES=2
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_RESET_SECONDS=60

# ── Logging ──────────────────────────────────────────────────
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# LOG_JSON: true = JSON lines (production), false = human-readable (dev)
LOG_JSON=false

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
